# Example backend configuration. Copy to .env and adjust as needed.
# All settings are optional; sensible demo defaults live in app/config.py.
# Every variable is prefixed with SHEO_.

# SHEO_DATABASE_URL=sqlite:///./sheo.db
# SHEO_JWT_SECRET=change-me-in-production
# SHEO_TELEMETRY_INTERVAL_SECONDS=2
# SHEO_DEFAULT_TARIFF_VND_PER_KWH=2500
# SHEO_SEED_ON_STARTUP=true
# SHEO_ENABLE_BACKGROUND=true     # set false to disable the simulator/scheduler loops
